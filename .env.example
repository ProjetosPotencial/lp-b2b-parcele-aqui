# =============================================================
# LP B2B Parcele Aqui - Mar Aberto V1 (POTUX-003)
# Copie este arquivo para .env.local e preencha os valores
# =============================================================

# URL pública da LP (sem barra no final)
NEXT_PUBLIC_SITE_URL=https://parceleaqui.com.br

# Integração com Komo (CRM/captura de leads)
# Preencher com URL do webhook ou endpoint da API Komo
KOMO_WEBHOOK_URL=
KOMO_API_KEY=
KOMO_LIST_ID=

# Origem para identificar leads desta LP no CRM
LEAD_SOURCE=lp-b2b-mar-aberto-v1

# E-mail de notificação fallback (caso Komo falhe)
NOTIFICATION_EMAIL=comercial@parceleaqui.com.br

# Rate limit (segundos entre submissões por IP)
RATE_LIMIT_SECONDS=10
